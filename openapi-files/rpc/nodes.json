  "info": {
    "title": "node-api",
    "description": "The node-api provider",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [{ "url": "/" }],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "in": "header",
        "type": "http"
      }
    },
    "schemas": {
      "InfoResponseDto": {
        "type": "object",
        "properties": {
          "uptime": {
            "type": "number",
            "description": "The total uptime of the service"
          }
        },
        "required": ["uptime"]
      },
      "JsonRpcRequestDto": {
        "type": "object",
        "properties": {
          "jsonrpc": {
            "type": "string",
            "default": "2.0",
            "description": "",
            "example": "2.0"
          },
          "id": { "type": "number", "description": "", "example": 1 },
          "method": {
            "type": "string",
            "enum": [
              "eth_blockNumber",
              "eth_call",
              "eth_chainId",
              "eth_createAccessList",
              "eth_estimateGas",
              "eth_feeHistory",
              "eth_gasPrice",
              "eth_getBalance",
              "eth_getBlockByHash",
              "eth_getBlockByNumber",
              "eth_getBlockTransactionCountByHash",
              "eth_getBlockTransactionCountByNumber",
              "eth_getBlockReceipts",
              "eth_getCode",
              "eth_getLogs",
              "eth_getProof",
              "eth_getStorageAt",
              "eth_getTransactionByHash",
              "eth_getTransactionByBlockHashAndIndex",
              "eth_getTransactionByBlockNumberAndIndex",
              "eth_getTransactionCount",
              "eth_getTransactionReceipt",
              "eth_getUncleByBlockHashAndIndex",
              "eth_getUncleByBlockNumberAndIndex",
              "eth_getUncleCountByBlockHash",
              "eth_getUncleCountByBlockNumber",
              "eth_maxPriorityFeePerGas",
              "eth_sendRawTransaction",
              "net_version",
              "web3_clientVersion",
              "eth_getTransactions",
              "eth_getDecodedTransactions",
              "eth_getTokenBalances",
              "eth_getTokenPrice",
              "eth_getTokenApprovals",
              "eth_getTokenMetadata",
              "eth_getNFTBalances",
              "eth_getNFTCollections",
              "eth_getNFTMetadata"
            ],
            "description": ""
          },
          "params": {
            "description": "",
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["jsonrpc", "id", "method"]
      },
      "JsonRpcErrorResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "number", "description": "", "example": -32000 },
          "message": {
            "type": "string",
            "description": "",
            "example": "execution reverted"
          }
        },
        "required": ["code", "message"]
      },
      "JsonRpcResponseDto": {
        "type": "object",
        "properties": {
          "jsonrpc": { "type": "string", "description": "", "example": "2.0" },
          "id": { "type": "number", "description": "", "example": 1 },
          "result": {
            "type": "string",
            "nullable": true,
            "description": "",
            "example": "0x1285f2e"
          },
          "error": {
            "description": "",
            "allOf": [{ "$ref": "#/components/schemas/JsonRpcErrorResponse" }]
          }
        },
        "required": ["jsonrpc", "id"]
      },
      "SupportedMethodDto": {
        "type": "object",
        "properties": {
          "chain": {
            "enum": [
              "eth",
              "sepolia",
              "holesky",
              "base",
              "base-sepolia",
              "polygon",
              "amoy",
              "bsc",
              "bsc-testnet",
              "arbitrum",
              "arbitrum-sepolia",
              "optimism",
              "optimism-sepolia",
              "gnosis",
              "gnosis-testnet",
              "linea",
              "linea-sepolia",
              "avalanche",
              "moonbeam",
              "moonriver",
              "moonbase",
              "blast",
              "blast-sepolia",
              "mantle",
              "mantle-sepolia",
              "polygon-zkevm",
              "polygon-zkevm-cardona",
              "zksync",
              "zksync-sepolia",
              "zetachain",
              "zetachain-testnet",
              "fantom",
              "opbnb",
              "flow",
              "flow-testnet",
              "ronin",
              "ronin-testnet",
              "lisk",
              "lisk-sepolia",
              "pulse"
            ],
            "type": "string",
            "description": ""
          },
          "supportedMethods": {
            "description": "",
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["chain", "supportedMethods"]
      },
      "ChainInfoDto": {
        "type": "object",
        "properties": {
          "chainId": { "type": "string", "description": "" },
          "chain": { "type": "string", "description": "" },
          "network": { "type": "string", "description": "" },
          "chainUrl": { "type": "string", "description": "" },
          "nodeUrls": {
            "description": "",
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["chainId", "chain", "network", "chainUrl", "nodeUrls"]
      }
    }
  }
}